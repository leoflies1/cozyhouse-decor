---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  pubDate: Date;
  heroImage?: string;
}

const { title, description, slug, category, pubDate, heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Living Room': 'bg-cozy-green/10 text-cozy-green',
  'Bedroom': 'bg-gold/10 text-gold',
  'Bathroom': 'bg-blue-100 text-blue-700',
  'Seasonal': 'bg-rose-100 text-rose-600',
  'Tips & DIY': 'bg-amber-100 text-amber-700',
};

const badgeClass = categoryColors[category] ?? 'bg-beige text-dark';
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 border border-beige/50">
  <!-- Image -->
  <a href={`/blog/${slug}`} class="block overflow-hidden aspect-[4/3] bg-beige relative">
    {heroImage ? (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-beige to-cream">
        <span class="text-5xl opacity-30">🏠</span>
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="p-5">
    <!-- Category + Date -->
    <div class="flex items-center justify-between mb-3">
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${badgeClass}`}>
        {category}
      </span>
      <time datetime={pubDate.toISOString()} class="text-xs text-dark/50">
        {formattedDate}
      </time>
    </div>

    <!-- Title -->
    <h2 class="font-serif text-lg font-bold text-dark leading-snug mb-2 group-hover:text-gold transition-colors duration-200">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>

    <!-- Description -->
    <p class="text-sm text-dark/60 leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>

    <!-- Read More -->
    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold hover:text-dark transition-colors duration-200"
    >
      Read More
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>

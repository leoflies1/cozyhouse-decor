---
const currentYear = new Date().getFullYear();
---

<footer class="bg-beige border-t border-beige/60 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand Column -->
      <div>
        <a href="/" class="font-serif text-2xl font-bold text-gold hover:text-dark transition-colors duration-200">
          CozyHouse
        </a>
        <p class="mt-3 text-sm text-dark/70 leading-relaxed">
          Your guide to a more beautiful, comfortable home. Honest decor inspiration, budget-friendly ideas, and curated product picks for every room.
        </p>
        <!-- Pinterest Social -->
        <a
          href="https://pinterest.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 text-sm text-dark/60 hover:text-gold transition-colors duration-200"
          aria-label="Follow CozyHouse on Pinterest"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
          </svg>
          Follow on Pinterest
        </a>
      </div>

      <!-- Navigation Column -->
      <div>
        <h3 class="font-serif text-lg font-semibold text-dark mb-4">Explore</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Blog</a></li>
          <li><a href="/categories/living-room" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Living Room</a></li>
          <li><a href="/categories/bedroom" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Bedroom</a></li>
          <li><a href="/categories/bathroom" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Bathroom</a></li>
          <li><a href="/categories/seasonal" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Seasonal</a></li>
          <li><a href="/categories/tips" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Tips & DIY</a></li>
        </ul>
      </div>

      <!-- Info Column -->
      <div>
        <h3 class="font-serif text-lg font-semibold text-dark mb-4">Info</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">About CozyHouse</a></li>
          <li><a href="/shop" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">Shop</a></li>
          <li>
            <a href="/about#affiliate" class="text-sm text-dark/70 hover:text-gold transition-colors duration-150">
              Affiliate Disclosure
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-6 border-t border-beige/80 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-dark/50">
        &copy; {currentYear} CozyHouse. All rights reserved.
      </p>
      <p class="text-xs text-dark/40 text-center sm:text-right max-w-md">
        This site contains affiliate links. We may earn a small commission on purchases made through our links, at no extra cost to you.
      </p>
    </div>
  </div>
</footer>

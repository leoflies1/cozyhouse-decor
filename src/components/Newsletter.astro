---
---

<section class="bg-gradient-to-br from-beige to-cream rounded-3xl px-6 py-12 md:px-12 md:py-16 text-center border border-beige/60">
  <div class="max-w-xl mx-auto">
    <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-3">Free Newsletter</p>
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-dark mb-4">
      Get Weekly Decor Inspiration
    </h2>
    <p class="text-dark/60 text-base leading-relaxed mb-8">
      Join thousands of home lovers who get our curated weekly picks — seasonal decor ideas, budget-friendly finds, room makeovers, and honest product recommendations. No spam, ever.
    </p>

    <form
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      action="#"
      method="POST"
    >
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 px-5 py-3 rounded-xl border border-beige bg-white text-dark placeholder-dark/40 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold text-sm transition-all duration-200"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-gold text-white rounded-xl font-semibold text-sm hover:bg-dark transition-colors duration-200 whitespace-nowrap"
      >
        Subscribe Free
      </button>
    </form>

    <p class="mt-4 text-xs text-dark/40">
      We respect your privacy. Unsubscribe anytime.
    </p>

    <!-- Trust indicators -->
    <div class="mt-8 flex flex-wrap justify-center gap-6 text-xs text-dark/50">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-cozy-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Weekly decor ideas
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-cozy-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Budget-friendly finds
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-cozy-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Seasonal inspiration
      </span>
    </div>
  </div>
</section>

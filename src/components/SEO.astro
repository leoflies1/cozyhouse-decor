---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  pubDate?: Date;
  tags?: string[];
}

const {
  title,
  description,
  image = '/logo.jpg',
  type = 'website',
  pubDate,
  tags = [],
} = Astro.props;

const siteUrl = 'https://cozyhouse.vercel.app';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageURL = new URL(image, siteUrl);
---

<!-- Primary Meta Tags -->
<title>{title} | CozyHouse</title>
<meta name="title" content={`${title} | CozyHouse`} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | CozyHouse`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content="CozyHouse" />

<!-- Twitter / Pinterest -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={`${title} | CozyHouse`} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

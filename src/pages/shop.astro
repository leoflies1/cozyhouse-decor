---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
---

<BaseLayout
  title="Shop — Digital Products Coming Soon"
  description="CozyHouse digital products are coming soon — printable wall art, room planning guides, and seasonal decor checklists for your home."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-gold/10 via-cream to-beige/40 py-20 md:py-32 text-center border-b border-beige">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <span class="text-5xl block mb-6">🏡</span>
      <p class="text-gold font-semibold text-xs uppercase tracking-widest mb-4">Coming Soon</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-dark mb-6 leading-tight">
        Digital Products<br />for Your Home
      </h1>
      <p class="text-dark/60 text-lg leading-relaxed">
        We are building a collection of thoughtfully designed digital resources to make your decorating journey easier, more organized, and more beautiful. Sign up below to be first to know when we launch.
      </p>
    </div>
  </section>

  <!-- What's Coming -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <p class="text-gold font-semibold text-xs uppercase tracking-widest mb-3">What We Are Building</p>
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-dark">Coming to the CozyHouse Shop</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {
          icon: '🖼️',
          title: 'Printable Wall Art',
          description: 'Curated, high-resolution art prints in styles ranging from botanical illustrations to modern minimalist typography. Download, print at home or at a local print shop, and frame. Instant home refresh at a fraction of the cost of gallery art.',
          tag: 'Launching Spring 2026',
        },
        {
          icon: '📐',
          title: 'Room Planner Guides',
          description: 'Step-by-step room planning worksheets and guides for living rooms, bedrooms, and open-plan spaces. Includes furniture placement templates, color palette worksheets, and shopping list templates organized by room.',
          tag: 'Launching Summer 2026',
        },
        {
          icon: '✅',
          title: 'Seasonal Decor Checklists',
          description: 'Comprehensive seasonal decorating checklists for every quarter — spring refresh, summer entertaining, fall cozy season, and holiday decor. Includes product recommendation lists with links to budget-friendly options.',
          tag: 'Launching Fall 2026',
        },
      ].map(item => (
        <div class="bg-white rounded-2xl p-8 border border-beige shadow-sm">
          <span class="text-4xl block mb-5">{item.icon}</span>
          <span class="text-xs font-semibold text-cozy-green bg-cozy-green/10 px-2.5 py-1 rounded-full">{item.tag}</span>
          <h3 class="font-serif text-xl font-bold text-dark mt-4 mb-3">{item.title}</h3>
          <p class="text-dark/60 text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-20">
    <Newsletter />
  </section>
</BaseLayout>
